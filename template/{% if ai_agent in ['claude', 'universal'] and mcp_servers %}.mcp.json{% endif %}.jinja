{
  "mcpServers": {
{%- set entries = [] -%}
{%- if 'github' in mcp_servers -%}
{%- set _ = entries.append('    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }') -%}
{%- endif -%}
{%- if 'filesystem' in mcp_servers -%}
{%- set _ = entries.append('    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${PWD}"]
    }') -%}
{%- endif -%}
{%- if 'fetch' in mcp_servers -%}
{%- set _ = entries.append('    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }') -%}
{%- endif -%}
{%- if 'playwright' in mcp_servers -%}
{%- set _ = entries.append('    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }') -%}
{%- endif -%}
{%- if 'postgres' in mcp_servers -%}
{%- set _ = entries.append('    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${POSTGRES_CONNECTION_STRING}"]
    }') -%}
{%- endif %}
{{ entries | join(',\n') }}
  }
}
