# Copy to .env and fill in. Do not commit .env.

# --- Application ---
APP_ENV=development
LOG_LEVEL=info

{% if 'github' in mcp_servers %}
# --- MCP: GitHub ---
# Personal access token with `repo` and `read:org` scopes minimum.
# https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=
{% endif %}
{% if 'postgres' in mcp_servers %}
# --- MCP: Postgres ---
# Connection string for the read-only role the MCP server will use.
POSTGRES_CONNECTION_STRING=postgresql://readonly_user:password@localhost:5432/dbname
{% endif %}
{% if 'filesystem' in mcp_servers %}
# --- MCP: Filesystem ---
# Comma-separated list of paths the filesystem server is allowed to read.
# Configured directly in .mcp.json by default; uncomment to override at runtime.
# MCP_FILESYSTEM_ROOTS={{ '${PWD}' }}
{% endif %}
{% if 'context7' in mcp_servers %}
# --- MCP: Context7 ---
# Free tier requires no API key. For higher rate limits, sign up at
# https://context7.com and uncomment / fill in:
# CONTEXT7_API_KEY=
{% endif %}
