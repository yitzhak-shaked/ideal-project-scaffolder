{
  "name": "{{ project_name | replace('_', '-') | replace(' ', '-') | lower }}",
  "version": "0.1.0",
  "private": true,
  {% if project_description %}"description": "{{ project_description }}",
  {% endif %}"type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "@types/node": "^22.0.0"
  }
  {% if author_name %},
  "author": "{{ author_name }}{% if author_email %} <{{ author_email }}>{% endif %}"
  {% endif %}
}
