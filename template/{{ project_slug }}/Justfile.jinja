# {{ project_name }} — task runner
# Run `just` to list available recipes.

# Use PowerShell on Windows; keep the default sh on Unix.
set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]

default:
    @just --list

{% if 'rust' in languages %}
# --- Rust ---
rust-build:
    cargo build

rust-test:
    cargo test

rust-fmt:
    cargo fmt --all

rust-lint:
    cargo clippy --all-targets --all-features -- -D warnings
{% endif %}
{% if 'python' in languages %}
# --- Python ---
py-install:
    uv sync

py-test:
    uv run pytest

py-fmt:
    uv run ruff format .

py-lint:
    uv run ruff check .

py-typecheck:
    uv run mypy src tests
{% endif %}
{% if 'cpp' in languages %}
# --- C/C++ ---
cpp-configure:
    cmake -S . -B build

cpp-build:
    cmake --build build

cpp-test:
    ctest --test-dir build --output-on-failure
{% endif %}
{% if 'typescript' in languages %}
# --- TypeScript / Node ---
ts-install:
    npm install

ts-build:
    npm run build

ts-test:
    npm test

ts-lint:
    npm run lint
{% endif %}

# Aggregate
test:
{% if 'rust' in languages %}    just rust-test
{% endif %}{% if 'python' in languages %}    just py-test
{% endif %}{% if 'cpp' in languages %}    just cpp-test
{% endif %}{% if 'typescript' in languages %}    just ts-test
{% endif %}

lint:
{% if 'rust' in languages %}    just rust-lint
{% endif %}{% if 'python' in languages %}    just py-lint
{% endif %}{% if 'typescript' in languages %}    just ts-lint
{% endif %}
{% if mcp_servers %}
# Diagnose MCP server setup: runtimes, env vars, and follow-up actions.
# Single command that tells you everything needed to get MCP working.
mcp:
    python scripts/mcp_check.py
{% endif %}
# --- Agent helpers ---
# These recipes don't run code; they print the right skill and instruction
# file paths to load. Pipe them into your agent ("paste this in chat") or
# use them as a quick reminder of what's available.

# List every project skill (one-liner descriptions).
skills:
    @echo "Project skills (load via: read {{ ai_folder }}/skills/<name>/SKILL.md):"
    @ls -1 {{ ai_folder }}/skills | sed 's/^/  /'

# List every project subagent.
agents:
    @echo "Project subagents (load via: read {{ ai_folder }}/agents/<name>.md):"
    @ls -1 {{ ai_folder }}/agents | grep -v README | sed 's/^/  /'

# Print the instruction files you should load for a given language.
# Usage:  just convention python    just convention rust    just convention general
convention LANG="general":
    @if [ -d "{{ ai_folder }}/instructions/{{ '{{LANG}}' }}" ]; then \
        echo "Load these files for {{ '{{LANG}}' }}:" ; \
        find {{ ai_folder }}/instructions/{{ '{{LANG}}' }} -name '*.md' | sed 's/^/  /' ; \
    else \
        echo "No instruction folder at {{ ai_folder }}/instructions/{{ '{{LANG}}' }}" ; \
        echo "Available: " ; \
        ls -1 {{ ai_folder }}/instructions ; \
    fi

# Print the design-review checklist for a file.
# Usage:  just review-design src/domain/order.py
review-design FILE:
    @echo "To review {{ '{{FILE}}' }}, load this skill and apply it to the file:"
    @echo "  {{ ai_folder }}/skills/design-review/SKILL.md"
    @echo ""
    @echo "Then read the file:"
    @echo "  {{ '{{FILE}}' }}"

# Print the TDD-cycle skill for an upcoming change.
# Usage:  just tdd "add refund-when-unpaid validation"
tdd DESCRIPTION:
    @echo "Drive '{{ '{{DESCRIPTION}}' }}' through the TDD cycle:"
    @echo "  1. Load {{ ai_folder }}/skills/tdd-cycle/SKILL.md"
    @echo "  2. Build a test list for the change."
    @echo "  3. Red → Green → Refactor, one item at a time."

# Print the refactor-code-smell skill for a file.
# Usage:  just refactor src/domain/order.py
refactor FILE:
    @echo "To refactor {{ '{{FILE}}' }}, load this skill and apply it:"
    @echo "  {{ ai_folder }}/skills/refactor-code-smell/SKILL.md"
    @echo ""
    @echo "Then read the file:"
    @echo "  {{ '{{FILE}}' }}"
{% if use_spec_kit %}
# --- Spec-Driven Development (spec-kit) ---
# Install spec-kit's slash commands into this project (one time; re-run to
# upgrade). Pulls the current spec-kit from GitHub. After it runs, the
# /speckit.* commands are available to your agent and spec-kit's skills
# land in .claude/skills/speckit-* alongside the scaffolder's vendored
# skills. See the SDD guide at {{ ai_folder }}/instructions/general/sdd.md
sdd-init:
    uvx --from git+https://github.com/github/spec-kit.git specify init --here{% if ai_agent in ['claude', 'copilot'] %} --ai {{ ai_agent }}{% else %} --ai claude{% endif %} --integration-options "--skills" --force

# --- Project skills ---
# Show the YAML frontmatter of each vendored / project-local skill so you
# can see at a glance which skills will be auto-suggested to the agent.
skills-list:
    @find {{ ai_folder }}/skills -name SKILL.md -print -exec head -5 {} \; -exec echo "" \;
{% else %}
# --- Project skills ---
# Show the YAML frontmatter of each vendored / project-local skill so you
# can see at a glance which skills will be auto-suggested to the agent.
skills-list:
    @find {{ ai_folder }}/skills -name SKILL.md -print -exec head -5 {} \; -exec echo "" \;
{% endif %}
